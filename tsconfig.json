{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["svelte"],
    "baseUrl": ".",
    "paths": { "$shared/*": ["src/shared/*"] },
    "outDir": "dist"
  },
  "include": ["src/client/**/*", "src/shared/**/*"],
  "exclude": ["node_modules"]
}
